<section class="bevon-trust color-{{ section.settings.color_scheme }}">
  <div class="bevon-trust__grid">
    {% for block in section.blocks %}
      <div class="bevon-trust__item" {{ block.shopify_attributes }}>
        <div class="bevon-trust__icon">
          {% case block.settings.icon %}
            {% when 'shipping' %}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"/></svg>
            {% when 'secure' %}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            {% when 'quality' %}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
            {% when 'support' %}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" stroke-linecap="round"/></svg>
          {% endcase %}
        </div>
        <h3 class="bevon-trust__title">{{ block.settings.title }}</h3>
        <p class="bevon-trust__desc">{{ block.settings.description }}</p>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "bevon Trust-Bar",
  "tag": "section",
  "max_blocks": 4,
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Farbschema", "default": "scheme-1" }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust-Item",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [
          { "value": "shipping", "label": "Versand" },
          { "value": "secure", "label": "Sicherheit" },
          { "value": "quality", "label": "Qualität" },
          { "value": "support", "label": "Support" }
        ], "default": "shipping" },
        { "type": "text", "id": "title", "label": "Titel", "default": "Kostenloser Versand" },
        { "type": "text", "id": "description", "label": "Beschreibung", "default": "Ab 50€ Bestellwert" }
      ]
    }
  ],
  "presets": [
    {
      "name": "bevon Trust-Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "shipping", "title": "Kostenloser Versand", "description": "Ab 50€ Bestellwert" } },
        { "type": "trust_item", "settings": { "icon": "secure", "title": "Sicherer Checkout", "description": "SSL-verschlüsselt" } },
        { "type": "trust_item", "settings": { "icon": "quality", "title": "Premium Qualität", "description": "Designed in Deutschland" } },
        { "type": "trust_item", "settings": { "icon": "support", "title": "24/7 Support", "description": "Schnelle Antwort garantiert" } }
      ]
    }
  ]
}
{% endschema %}
