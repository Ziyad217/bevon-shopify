<section class="bevon-countdown color-{{ section.settings.color_scheme }}">
  {% if section.settings.eyebrow != blank %}
    <p class="bevon-grid__eyebrow" style="color:#fff;opacity:.7;">{{ section.settings.eyebrow }}</p>
  {% endif %}
  <h2 class="bevon-countdown__heading">{{ section.settings.heading }}</h2>
  {% if section.settings.subheading != blank %}
    <p class="bevon-countdown__sub">{{ section.settings.subheading }}</p>
  {% endif %}

  <div class="bevon-countdown__timer" data-bevon-countdown="{{ section.settings.target_date }}">
    <div class="bevon-countdown__unit"><span class="bevon-countdown__num" data-unit="days">--</span><span class="bevon-countdown__label">Tage</span></div>
    <div class="bevon-countdown__unit"><span class="bevon-countdown__num" data-unit="hours">--</span><span class="bevon-countdown__label">Stunden</span></div>
    <div class="bevon-countdown__unit"><span class="bevon-countdown__num" data-unit="minutes">--</span><span class="bevon-countdown__label">Minuten</span></div>
    <div class="bevon-countdown__unit"><span class="bevon-countdown__num" data-unit="seconds">--</span><span class="bevon-countdown__label">Sekunden</span></div>
  </div>

  {% if section.settings.button_label != blank %}
    <a href="{{ section.settings.button_link | default: '#' }}" class="bevon-countdown__cta">{{ section.settings.button_label }}</a>
  {% endif %}

  {% if section.settings.trust_text != blank %}
    <p class="bevon-countdown__trust">{{ section.settings.trust_text }}</p>
  {% endif %}
</section>

<script>
(function() {
  var el = document.querySelector('[data-bevon-countdown]');
  if (!el) return;
  var target = new Date(el.getAttribute('data-bevon-countdown')).getTime();
  if (isNaN(target)) return;
  function tick() {
    var now = Date.now();
    var diff = Math.max(0, target - now);
    var d = Math.floor(diff / 86400000);
    var h = Math.floor((diff % 86400000) / 3600000);
    var m = Math.floor((diff % 3600000) / 60000);
    var s = Math.floor((diff % 60000) / 1000);
    var pad = function(n){ return n < 10 ? '0' + n : '' + n; };
    var parts = el.querySelectorAll('[data-unit]');
    parts.forEach(function(p) {
      var u = p.getAttribute('data-unit');
      p.textContent = u === 'days' ? d : pad(u === 'hours' ? h : u === 'minutes' ? m : s);
    });
  }
  tick();
  setInterval(tick, 1000);
})();
</script>

{% schema %}
{
  "name": "bevon Countdown",
  "tag": "section",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Farbschema", "default": "scheme-4" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "LIMITIERTER DROP" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "NUR NOCH KURZE ZEIT" },
    { "type": "text", "id": "subheading", "label": "Untertitel", "default": "Sichere dir den WM 2026 Drop bevor er ausverkauft ist." },
    { "type": "text", "id": "target_date", "label": "Zieldatum (YYYY-MM-DD HH:MM)", "default": "2026-06-11 18:00", "info": "Format: 2026-06-11 18:00" },
    { "type": "text", "id": "button_label", "label": "Button-Text", "default": "JETZT DROP SICHERN" },
    { "type": "url", "id": "button_link", "label": "Button-Link" },
    { "type": "text", "id": "trust_text", "label": "Trust-Zeile", "default": "30 Tage Rückgabe · Kostenloser Versand ab 50€ · Premium Qualität" }
  ],
  "presets": [{ "name": "bevon Countdown" }]
}
{% endschema %}
