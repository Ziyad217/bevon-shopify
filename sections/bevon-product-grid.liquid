<section class="bevon-grid color-{{ section.settings.color_scheme }}">
  <div class="bevon-grid__inner">
    <div class="bevon-grid__header">
      {% if section.settings.eyebrow != blank %}
        <p class="bevon-grid__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="bevon-grid__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="bevon-grid__sub">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="bevon-grid__cards">
      {% for block in section.blocks %}
        {%- assign product = all_products[block.settings.product] -%}
        <a href="{% if product != blank %}{{ product.url }}{% else %}{{ block.settings.fallback_link | default: '#' }}{% endif %}"
           class="bevon-grid__card" {{ block.shopify_attributes }}>
          <div class="bevon-grid__image">
            {% if product != blank and product.featured_image %}
              {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: product.title, sizes: '(min-width: 990px) 33vw, 100vw', widths: '300, 500, 800' }}
            {% elsif block.settings.image %}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {% else %}
              <div style="display:flex;align-items:center;justify-content:center;height:100%;color:#bbb;background:var(--bevon-surface);">Produktbild</div>
            {% endif %}
            {% if block.settings.badge != blank %}
              <span class="bevon-grid__badge">{{ block.settings.badge }}</span>
            {% endif %}
          </div>
          <div class="bevon-grid__body">
            <h3 class="bevon-grid__title">{{ block.settings.title | default: product.title }}</h3>
            <p class="bevon-grid__price">
              {% if product != blank %}{{ product.price | money }}{% else %}{{ block.settings.fallback_price | default: '€34,99' }}{% endif %}
            </p>
            <span class="bevon-grid__cta">{{ block.settings.cta_label | default: 'JETZT KAUFEN' }}</span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "bevon Produkt-Grid",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Farbschema", "default": "scheme-2" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "LIMITIERTER DROP" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "MEISTGEFRAGTE DESIGNS" },
    { "type": "text", "id": "subheading", "label": "Untertitel", "default": "Drei Designs. Ein Drop. Kein Restock." }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Produkt-Karte",
      "settings": [
        { "type": "product", "id": "product", "label": "Produkt" },
        { "type": "image_picker", "id": "image", "label": "Fallback-Bild" },
        { "type": "text", "id": "title", "label": "Titel-Override" },
        { "type": "text", "id": "badge", "label": "Badge", "default": "LIMITIERT" },
        { "type": "text", "id": "fallback_price", "label": "Fallback-Preis", "default": "€34,99" },
        { "type": "url", "id": "fallback_link", "label": "Fallback-Link" },
        { "type": "text", "id": "cta_label", "label": "CTA-Text", "default": "JETZT KAUFEN" }
      ]
    }
  ],
  "presets": [
    {
      "name": "bevon Produkt-Grid",
      "blocks": [
        { "type": "product_card", "settings": { "badge": "LIMITIERT", "title": "Sommermärchen 2.0" } },
        { "type": "product_card", "settings": { "badge": "BESTSELLER", "title": "Wir holen es" } },
        { "type": "product_card", "settings": { "badge": "FAN FAVORITE", "title": "WM 2026 Deutschland" } }
      ]
    }
  ]
}
{% endschema %}
