<section class="bevon-carousel color-{{ section.settings.color_scheme }}">
  <div class="bevon-carousel__header">
    {% if section.settings.eyebrow != blank %}
      <p class="bevon-grid__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="bevon-grid__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="bevon-grid__sub">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>

  <div class="bevon-carousel__track">
    {%- assign collection = collections[section.settings.collection] -%}
    {% if collection != blank and collection.products.size > 0 %}
      {% for product in collection.products limit: section.settings.products_to_show %}
        <a href="{{ product.url }}" class="bevon-carousel__item bevon-grid__card" style="text-decoration:none;">
          <div class="bevon-grid__image">
            {% if product.featured_image %}
              {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title, sizes: '280px', widths: '280, 560' }}
            {% endif %}
          </div>
          <div class="bevon-grid__body">
            <h3 class="bevon-grid__title">{{ product.title }}</h3>
            <p class="bevon-grid__price">{{ product.price | money }}</p>
          </div>
        </a>
      {% endfor %}
    {% else %}
      {% for i in (1..6) %}
        <div class="bevon-carousel__item bevon-grid__card">
          <div class="bevon-grid__image">
            <div style="display:flex;align-items:center;justify-content:center;height:100%;color:#bbb;background:var(--bevon-surface);">Produkt {{ i }}</div>
          </div>
          <div class="bevon-grid__body">
            <h3 class="bevon-grid__title">Produkt-Platzhalter {{ i }}</h3>
            <p class="bevon-grid__price">€34,99</p>
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "bevon Carousel",
  "tag": "section",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Farbschema", "default": "scheme-1" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "LIMITED DROP" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Exklusive Football Shirts zur WM 2026" },
    { "type": "text", "id": "subheading", "label": "Untertitel", "default": "Limitierte Drops — kein Restock. Sichere dir dein Design zur WM 2026." },
    { "type": "collection", "id": "collection", "label": "Kollektion" },
    { "type": "range", "id": "products_to_show", "label": "Anzahl Produkte", "min": 4, "max": 16, "step": 1, "default": 8 }
  ],
  "presets": [{ "name": "bevon Carousel" }]
}
{% endschema %}
